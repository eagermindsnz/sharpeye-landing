---
import { site } from '../data/site';
---

<section class="section contact" id="contact" aria-labelledby="contact-title">
	<div class="wrap contact__grid">
		<div>
			<p class="section__label">Contact</p>
			<h2 class="section__title" id="contact-title">Tell us about your programme — we will respond with next steps.</h2>
			<p class="section__lead">
				For drawings, variations, or site measures, reach us on the phone or email below. If you already
				use Sharpeye Mate, reference your order number for faster routing.
			</p>
			<address class="contact__address">
				<strong>{site.legalName}</strong><br />
				{site.address.street}<br />
				{site.address.city}, {site.address.country}
			</address>
		</div>
		<div class="contact__card">
			<h3 class="contact__h">Need help?</h3>
			<p class="contact__row">
				<span class="contact__k">Phone</span>
				<a href={`tel:${site.phoneTel}`}>{site.phoneDisplay}</a>
			</p>
			<p class="contact__row">
				<span class="contact__k">Email</span>
				<a href={`mailto:${site.email}`}>{site.email}</a>
			</p>
			<div class="contact__actions">
				<a class="btn btn--primary" href={`mailto:${site.email}?subject=Project%20enquiry`}>Email the team</a>
				<a class="btn btn--dark" href={`tel:${site.phoneTel}`}>Call now</a>
			</div>
			<p class="contact__fineprint">Typical response: same business day for calls, 1–2 days for detailed email briefs.</p>
		</div>
	</div>
</section>

<style>
	.contact {
		background: linear-gradient(135deg, rgba(31, 143, 84, 0.08), transparent 45%), var(--bg);
		border-top: 1px solid var(--line);
	}

	.contact__grid {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: clamp(2rem, 5vw, 3rem);
		align-items: start;
	}

	.contact__address {
		margin-top: 1.5rem;
		font-style: normal;
		color: var(--ink-muted);
		line-height: 1.6;
	}

	.contact__address strong {
		color: var(--ink);
	}

	.contact__card {
		background: var(--bg-elevated);
		border: 1px solid var(--line);
		border-radius: var(--radius-lg);
		padding: 1.75rem 1.75rem 1.5rem;
		box-shadow: var(--shadow);
	}

	.contact__h {
		margin: 0 0 1.25rem;
		font-size: 1.1rem;
	}

	.contact__row {
		display: grid;
		grid-template-columns: 100px 1fr;
		gap: 0.5rem 1rem;
		margin: 0 0 0.85rem;
		align-items: baseline;
		font-size: 1rem;
	}

	.contact__k {
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		font-weight: 600;
		color: var(--ink-muted);
	}

	.contact__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		margin-top: 1.5rem;
	}

	.contact__fineprint {
		margin: 1.25rem 0 0;
		font-size: 0.88rem;
		color: var(--ink-muted);
	}

	@media (max-width: 800px) {
		.contact__grid {
			grid-template-columns: 1fr;
		}
	}
</style>
