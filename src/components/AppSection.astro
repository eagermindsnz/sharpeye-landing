---
import { assetUrl, site } from '../data/site';
---

<section class="section" id="app" aria-labelledby="app-title">
	<div class="wrap app">
		<div class="app__copy">
			<p class="section__label">Sharpeye Mate</p>
			<h2 class="section__title" id="app-title">Track fabrication and deliveries in one place.</h2>
			<p class="section__lead">
				Sharpeye Mate helps you create and track orders so you can line up installers, site access, and
				sequencing without chasing email threads.
			</p>
			<p class="app__note">
				Ask the sales team for access details — we will point you to the current App Store / Google Play
				listing for your account.
			</p>
			<a class="btn btn--dark" href="#contact">Request app access</a>
		</div>
		<div class="app__visual" aria-hidden="true">
			<img src={assetUrl('/img/appLaunch.jpg')} alt="" width="640" height="640" loading="lazy" />
		</div>
	</div>
</section>

<style>
	.app {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: center;
	}

	.app__note {
		margin: 1rem 0 1.5rem;
		font-size: 0.95rem;
		color: var(--ink-muted);
		max-width: 52ch;
	}

	.app__visual {
		border-radius: var(--radius-lg);
		overflow: hidden;
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
		background: var(--bg-elevated);
	}

	.app__visual img {
		width: 100%;
		height: auto;
		display: block;
	}

	@media (max-width: 820px) {
		.app {
			grid-template-columns: 1fr;
		}
	}
</style>
