---
import { site } from '../data/site';
---

<section class="section section--muted" id="about" aria-labelledby="about-title">
	<div class="wrap about">
		<div class="about__text">
			<p class="section__label">Who we are</p>
			<h2 class="section__title" id="about-title">Importer, fabricator, and installation partner since {site.since}.</h2>
			<p class="about__p">
				Sharpeye Ltd has served New Zealand clients since June {site.since}. We began by importing quality
				furniture, then expanded into kitchens, bathrooms, glass balustrades, and broader building products
				— combining overseas supply with Auckland-based fabrication and experienced installers.
			</p>
			<p class="about__p">
				Together with our partners, we work hard on the details — compliance, lead times, and finish — so
				your site team can move forward with confidence.
			</p>
			<a class="btn btn--dark" href="#contact">Plan a project with us</a>
		</div>
		<div class="about__media">
			<p class="section__label about__media-label">Sharpeye’s story</p>
			<div class="about__frame">
				<iframe
					title="Sharpeye company video"
					src={`https://www.youtube-nocookie.com/embed/${site.youtubeId}`}
					loading="lazy"
					allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
					allowfullscreen
				></iframe>
			</div>
		</div>
	</div>
</section>

<style>
	.about {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: clamp(2rem, 5vw, 3.5rem);
		align-items: start;
	}

	.about__p {
		margin: 0 0 1rem;
		color: var(--ink-muted);
		max-width: 56ch;
	}

	.about__p:last-of-type {
		margin-bottom: 1.5rem;
	}

	.about__media-label {
		margin-bottom: 0.75rem;
	}

	.about__frame {
		border-radius: var(--radius-lg);
		overflow: hidden;
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
		aspect-ratio: 16 / 9;
		background: #000;
	}

	.about__frame iframe {
		width: 100%;
		height: 100%;
		border: 0;
		display: block;
		min-height: 220px;
	}

	@media (max-width: 860px) {
		.about {
			grid-template-columns: 1fr;
		}
	}
</style>
