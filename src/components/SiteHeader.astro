---
import { site } from '../data/site';

const nav = [
	{ href: '#products', label: 'Products & services' },
	{ href: '#portfolio', label: 'Portfolio' },
	{ href: '#app', label: 'Sharpeye Mate' },
	{ href: '#about', label: 'About' },
	{ href: '#partners', label: 'Partners' },
	{ href: '#faq', label: 'FAQ' },
	{ href: '#contact', label: 'Contact' },
];
---

<header class="header">
	<div class="header__inner wrap">
		<a class="header__brand" href="#top" aria-label={`${site.name} home`}>
			<span class="header__mark" aria-hidden="true"></span>
			<span class="header__name">{site.name}</span>
		</a>
		<nav class="header__nav" aria-label="Primary">
			<ul>
				{nav.map((item) => (
					<li>
						<a href={item.href}>{item.label}</a>
					</li>
				))}
			</ul>
		</nav>
		<div class="header__cta">
			<a class="btn btn--primary" href={`tel:${site.phoneTel}`}>Call</a>
		</div>
	</div>
</header>

<style>
	.header {
		position: sticky;
		top: 0;
		z-index: 50;
		backdrop-filter: blur(14px);
		background: rgba(246, 244, 240, 0.86);
		border-bottom: 1px solid var(--line);
	}

	.header__inner {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		padding-block: 0.85rem;
	}

	.header__brand {
		display: inline-flex;
		align-items: center;
		gap: 0.65rem;
		text-decoration: none;
		color: var(--ink);
		font-weight: 700;
		letter-spacing: -0.03em;
		font-size: 1.2rem;
	}

	.header__brand:hover {
		color: var(--ink);
	}

	.header__mark {
		width: 12px;
		height: 12px;
		border-radius: 3px;
		background: linear-gradient(135deg, var(--brand), #2bb86f);
		box-shadow: 0 0 0 3px var(--brand-soft);
	}

	.header__nav {
		margin-left: auto;
		max-width: min(58vw, 640px);
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		mask-image: linear-gradient(to right, transparent, #000 12px, #000 calc(100% - 12px), transparent);
	}

	.header__nav ul {
		list-style: none;
		margin: 0;
		padding: 0 0.25rem;
		display: flex;
		flex-wrap: nowrap;
		gap: 0.35rem 1.05rem;
		justify-content: flex-end;
		width: max-content;
		margin-left: auto;
	}

	.header__nav a {
		text-decoration: none;
		font-weight: 500;
		font-size: 0.92rem;
		color: var(--ink-muted);
	}

	.header__nav a:hover {
		color: var(--ink);
	}

	.header__cta .btn {
		padding-inline: 1.1rem;
		font-size: 0.9rem;
	}

	@media (max-width: 640px) {
		.header__inner {
			flex-wrap: wrap;
		}

		.header__nav {
			order: 3;
			flex: 1 1 100%;
			max-width: none;
			mask-image: none;
		}

		.header__nav ul {
			justify-content: flex-start;
		}
	}
</style>
