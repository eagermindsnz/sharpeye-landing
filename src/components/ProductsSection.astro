---
import { products } from '../data/site';

function iconSvg(kind: (typeof products)[number]['icon']) {
	const s = (body: string) =>
		`<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">${body}</svg>`;
	const paths: Record<(typeof products)[number]['icon'], string> = {
		glass: s('<path d="M4 5h16v14H4z"/><path d="M8 5v14M16 5v14M4 9h16M4 15h16"/>'),
		stone: s('<path d="M3 21h18L12 3 3 21z"/><path d="M12 3v18"/>'),
		steel: s(
			'<circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>',
		),
		more: s('<circle cx="12" cy="12" r="1"/><circle cx="6" cy="12" r="1"/><circle cx="18" cy="12" r="1"/>'),
		service: s(
			'<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>',
		),
		barrier: s(
			'<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/>',
		),
		retrofit: s(
			'<rect x="3" y="5" width="18" height="14" rx="2"/><path d="M12 5v14M3 12h18"/><path d="M7 9h.01M17 15h.01"/>',
		),
		coord: s(
			'<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8M8 17h6"/>',
		),
	};
	return paths[kind];
}
---

<section class="section" id="products" aria-labelledby="products-title">
	<div class="wrap">
		<p class="section__label">Products & services</p>
		<h2 class="section__title" id="products-title">Everything for the envelope — glass, stone, steel, and site support.</h2>
		<p class="section__lead">
			From Auckland across New Zealand: imported lines plus local toughening and fabrication — with the
			documentation, compliance thinking, and site coordination specifiers and main contractors expect on
			today’s programmes.
		</p>
		<div class="card-grid section__grid">
			{
				products.map((p) => (
					<article class="card">
						<div class="card__icon" set:html={iconSvg(p.icon)} />
						<h3 class="card__title">{p.title}</h3>
						<p class="card__text">{p.description}</p>
						<a class="card__link" href={p.href} data-open-inquiry>
							Discuss this scope →
						</a>
					</article>
				))
			}
		</div>
	</div>
</section>

<style>
	.section__grid {
		margin-top: 2.25rem;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}
</style>
