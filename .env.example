# Optional. When set at build time, enables absolute og:url and JSON-LD for *this* host only.
# PUBLIC_SITE_URL=https://your-demo.pages.dev

# Optional. Formspree form id (from https://formspree.io/). If unset, Inquiry submit uses mailto (no file attachments).
# File uploads in the inquiry modal only appear when this is set; Formspree file hosting needs a paid tier — check their pricing.
# PUBLIC_FORMSPREE_ID=xxxxxxxx
